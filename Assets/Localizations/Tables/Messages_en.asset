  m_Name: Messages_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: ea952dfbebe54d14a85e6382df5e8d6c, type: 2}
  m_Metadata:
