  - m_Id: 42723011881857042
    m_Localized: "Vojensk\xE9 p\u0159edm\u011Bty"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857043
    m_Localized: Plastiky
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857044
    m_Localized: "B\u011B\u017En\xE9 p\u0159edm\u011Bty"
