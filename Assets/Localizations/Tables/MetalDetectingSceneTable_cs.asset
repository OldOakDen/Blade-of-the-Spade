    m_Metadata:
      m_Items: []
  - m_Id: 42728067985305605
    m_Localized: "P\u0159esnost lokalizace artefaktu"
    m_Metadata:
      m_Items: []
  - m_Id: 42974819342610432
    m_Localized: "Neidentifikovan\xFD p\u0159edm\u011Bt"
    m_Metadata:
      m_Items: []
  - m_Id: 43043444678193152
    m_Localized: "Vyber jednotliv\xE9 kategorie a odstra\u0148 kus hl\xEDny kliknut\xEDm
      na n\u011Bj."
    m_Metadata:
      m_Items: []
  - m_Id: 45190505678761984
    m_Localized: "S\xED\u0165 1cm zap./vyp."
    m_Metadata:
      m_Items: []
  - m_Id: 49915174570946560
    m_Localized: "Postupn\u011B p\u0159edm\u011Bt odkr\xFDvej. T\u0159eba pozn\xE1\u0161
      co jsi na\u0161el."
    m_Metadata:
      m_Items: []
  - m_Id: 52403600616583168
    m_Localized: "Ur\u010Duj kategorie v pr\u016Fb\u011Bhu \u010Di\u0161t\u011Bn\xED
      p\u0159edm\u011Btu. Pozoruj tvar a materi\xE1l."
    m_Metadata:
      m_Items: []
