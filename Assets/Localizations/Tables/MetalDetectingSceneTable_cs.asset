  m_SharedData: {fileID: 11400000, guid: e0d42265492ce85438b8c17847118906, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 57029160960
    m_Localized: "Stisk <color=red>mezern\xEDku</color> p\u0159ep\xEDn\xE1 do m\xF3du
      kop\xE1n\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 785877561344
    m_Localized: "Stisk <color=red>mezern\xEDku</color> t\u011B vr\xE1t\xED do m\xF3du
      hled\xE1n\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 42632781233385472
    m_Localized: "V\xEDtej na lokalit\u011B! Prozkoumej ji a najdi cenn\xE9 artefakty!"
    m_Metadata:
      m_Items: []
  - m_Id: 42632781254356992
    m_Localized: "Pohyb kup\u0159edu, zp\u011Bt a do bok\u016F - tla\u010D\xEDtka
      <color=red>WSAD</color>."
    m_Metadata:
      m_Items: []
  - m_Id: 42632781258551296
    m_Localized: "Podr\u017E tla\u010D\xEDtko <color=red>Shift</color> spolu se sm\u011Brov\xFDmi
      tla\u010D\xEDtky pro rychlej\u0161\xED pohyb."
    m_Metadata:
      m_Items: []
  - m_Id: 42632781258551297
    m_Localized: "Pohyb my\u0161\xED - ot\xE1\u010Den\xED se doprava a doleva."
    m_Metadata:
      m_Items: []
  - m_Id: 42632781258551298
    m_Localized: "Lev\xE9 tla\u010D\xEDtko my\u0161i zrychl\xED kmit\xE1n\xED c\xEDvkou
      pro p\u0159esn\u011Bj\u0161\xED lokalizaci c\xEDle. "
    m_Metadata:
      m_Items: []
  - m_Id: 42698646981177344
    m_Localized: "Prav\xE9 tla\u010D\xEDtko my\u0161i zap\xEDn\xE1 a vyp\xEDn\xE1
      <color=green>PINPOINT</color> m\xF3d."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371648
    m_Localized: "Lev\xE9 tla\u010D\xEDtko my\u0161i - kopej v m\xEDst\u011B kruhov\xE9ho
      ozna\u010Den\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371649
    m_Localized: "Pohybuj pomalu c\xEDvkou a najdi nejintenzivn\u011Bj\u0161\xED
      sign\xE1l pro bezpe\u010Dn\xE9 vyzvednut\xED p\u0159edm\u011Btu."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371650
    m_Localized: "V\xFDborn\u011B, poda\u0159ilo se ti n\u011Bco naj\xEDt!"
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371651
    m_Localized: "P\u0159idr\u017E prav\xE9 tla\u010D\xEDtko my\u0161i a pohybem
      my\u0161\xED rotuj s p\u0159edm\u011Btem."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371652
    m_Localized: "Lev\xFDm kliknut\xEDm my\u0161\xED na kus hl\xEDny ji odstran\xED\u0161."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371653
    m_Localized: "Kole\u010Dkem my\u0161i p\u0159ibli\u017Euj a oddaluj p\u0159edm\u011Bt."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371654
    m_Localized: "Pokus se identifikovat neo\u010Di\u0161t\u011Bn\xFD p\u0159edm\u011Bt
      a z\xEDskej tak bonusov\xE9 body."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371655
    m_Localized: "O\u010Distil jsi cel\xFD p\u0159edm\u011Bt. Dobr\xE1 pr\xE1ce!"
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371656
    m_Localized: "Nepoda\u0159ilo se ti identifikovat nalezen\xFD p\u0159edm\u011Bt."
    m_Metadata:
      m_Items: []
  - m_Id: 42698646985371657
    m_Localized: "Ur\u010Dil jsi spr\xE1vn\u011B v\u0161echny kategorie!"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857024
    m_Localized: "Z\xEDskej dal\u0161\xED informace o p\u0159edm\u011Btu ve sv\xE9
      pracovn\u011B a z\xEDskej tak dal\u0161\xED body."
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857025
    m_Localized: "Nev\xEDm"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857026
    m_Localized: "Doba kamenn\xE1 (3000+ p\u0159.n.l.)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857027
    m_Localized: "Doba bronzov\xE1 (3000p\u0159.n.l.-1200p\u0159.n.l.)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857028
    m_Localized: "Doba \u017Eelezn\xE1 (1200p\u0159.n.l.-500n.l.)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857029
    m_Localized: "Klasick\xE1 antika (500p\u0159.n.l.-500n.l.)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857030
    m_Localized: "St\u0159edov\u011Bk (500n.l.-1500n.l.)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857031
    m_Localized: "Ran\xFD novov\u011Bk (1500n.l.-1800n.l.)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857032
    m_Localized: "Novov\u011Bk (1800n.l.-sou\u010Dasnost)"
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857033
    m_Localized: Zlato
    m_Metadata:
      m_Items: []
  - m_Id: 42723011881857034
    m_Localized: "St\u0159\xEDbro"
    m_Metadata:
